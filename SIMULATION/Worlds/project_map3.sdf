<?xml version="1.0" ?>
<sdf version="1.7">

  <world name="CyberWaster_Sim2">

    <!-----Physics----->
    <plugin filename="libignition-gazebo-physics-system.so"
            name="ignition::gazebo::systems::Physics"/>

    <plugin filename="libignition-gazebo-scene-broadcaster-system.so"
            name="ignition::gazebo::systems::SceneBroadcaster"/>

    <!-----Sun Light----->
    <light type="directional" name="sun">
      <pose>0 0 10 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-----Ground Plane----->
    <model name="ground_floor">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <!-----9 x 9 floor----->
              <size>9 9</size>
            </plane>
          </geometry>
        </collision>

        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <!-----9 x 9 floor----->
              <size>9 9</size>
            </plane>
          </geometry>

          <!-----Color of floor----->
          <material>
            <ambient>0.30 0.14 0.10 1</ambient>
            <diffuse>0.30 0.14 0.10 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>


    <!----------Walls around 9x9 area---------->

    <model name="map_walls">
      <static>true</static>

      <!-----West Wall----->
      <link name="west_wall">
        <pose>0 4.55 0.5 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>9 0.1 1.0</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>9 0.1 1.0</size>
            </box>
          </geometry>
          <material>
            <ambient>0.96 0.90 0.75 1</ambient>
            <diffuse>0.96 0.90 0.75 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>

      <!-----East Wall----->
      <link name="east_wall">
        <pose>0 -4.55 0.5 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>9 0.1 1.0</size>
            </box>
          </geometry>
        </collision>

        <visual name="visual">
          <geometry>
            <box>
              <size>9 0.1 1.0</size>
            </box>
          </geometry>

          <material>
            <ambient>0.96 0.90 0.75 1</ambient>
            <diffuse>0.96 0.90 0.75 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
 
      <!-----North Wall----->
      <link name="north_wall">
        <pose>4.55 -0.7 0.5 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.1 7.8 1.0</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.1 7.8 1.0</size>
            </box>
          </geometry>
          <material>
            <ambient>0.96 0.90 0.75 1</ambient>
            <diffuse>0.96 0.90 0.75 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>

      <!-----South Wall----->
      <link name="south_wall">
        <pose>-4.55 0 0.5 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.1 9 1.0</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.1 9 1.0</size>
            </box>
          </geometry>
          <material>
            <ambient>0.96 0.90 0.75 1</ambient>
            <diffuse>0.96 0.90 0.75 1</diffuse>
            <specular>0.05 0.05 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>


      <!----------Reception Desk Area (L shaped)---------->
      <model name="reception_desk">
        <static>true</static>
        <pose>-2.1 3.0 -0.2 0 0 1.57</pose>

        <!-----Long side of desk----->
        <link name="long_side">
          <pose>0 0 0.5 0 0 0</pose>

          <collision name="collision">
            <geometry>
              <box>
                <size>3.0 0.7 0.5</size>
              </box>
            </geometry>
          </collision>

          <visual name="visual">
            <geometry>
              <box>
                <size>3.0 0.7 0.5</size>
              </box>
            </geometry>

            <material>
              <ambient>0.24 0.12 0.08 1</ambient>
              <diffuse>0.24 0.12 0.08 1</diffuse>
              <specular>0.05 0.05 0.05 1</specular>
            </material>
          </visual>
        </link>

        <!-----Short side of desk----->
        <link name="short_side">
          <pose>-1.15 0.70 0.5 0 0 1.57</pose>

          <collision name="collision">
            <geometry>
              <box>
                <size>1.2 0.7 0.5</size>
              </box>
            </geometry>
          </collision>

          <visual name="visual">
            <geometry>
              <box>
                <size>1.2 0.7 0.5</size>
              </box>
            </geometry>

            <material>
              <ambient>0.24 0.12 0.08 1</ambient>
              <diffuse>0.24 0.12 0.08 1</diffuse>
              <specular>0.05 0.05 0.05 1</specular>
            </material>
          </visual>
        </link>

         <!-----Computer on desk----->
         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/MonitorAndKeyboard</uri>
           <pose>0 -0.1 0.75 0 0 -1.57</pose>
           <name>computer</name>
         </include>

      </model>


      <!----------Seating Area 1---------->
      <model name="seating_area1">
      <pose>3.2 -3.2 0 0 0 0.78</pose>	

         <!-----Table----->
         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/CoffeeTable</uri>
           <pose>0 0 0.1 0 0 0</pose>
           <name>table1</name>
         </include>

         <!-----Chairs----->
         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Chair</uri>
           <pose>1 0 0.1 0 0 3.14</pose>
           <name>chair1</name>
         </include>

         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Chair</uri>
           <pose>0 1 0.1 0 0 -1.57</pose>
           <name>chair2</name>
         </include>

         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Chair</uri>
           <pose>0 -1 0.1 0 0 1.57</pose>
           <name>chair3</name>
         </include>

         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Chair</uri>
           <pose>-1 0 0.1 0 0 0</pose>
           <name>chair4</name>
         </include>

      </model>


      <!----------Seating Area 2---------->
      <model name="seating_area2">
      <pose>-0.5 -1.5 0 0 0 0</pose>

         <!-----Table----->
         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/CoffeeTable</uri>
           <pose>0 0 0.1 0 0 0</pose>
           <name>table2</name>
         </include>

         <!-----Chairs----->
         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Chair</uri>
           <pose>1 0 0.1 0 0 3.14</pose>
           <name>chair5</name>
         </include>

         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Chair</uri>
           <pose>0 1 0.1 0 0 -1.57</pose>
           <name>chair6</name>
         </include>

         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Chair</uri>
           <pose>0 -1 0.1 0 0 1.57</pose>
           <name>chair7</name>
         </include>

         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Chair</uri>
           <pose>-1 0 0.1 0 0 0</pose>
           <name>chair8</name>
         </include>

      </model>


      <!----------Seating Area 3---------->
      <model name="seating_area3">
      <pose>3.2 0.5 0 0 0 0.78</pose>

         <!-----Table----->
         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/CoffeeTable</uri>
           <pose>0 0 0.1 0 0 0</pose>
           <name>table3</name>
         </include>

         <!-----Chairs----->
         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Chair</uri>
           <pose>1 0 0.1 0 0 3.14</pose>
           <name>chair9</name>
         </include>

         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Chair</uri>
           <pose>0 1 0.1 0 0 -1.57</pose>
           <name>chair10</name>
         </include>

         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Chair</uri>
           <pose>0 -1 0.1 0 0 1.57</pose>
           <name>chair11</name>
         </include>

         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Chair</uri>
           <pose>-1 0 0.1 0 0 0</pose>
           <name>chair12</name>
         </include>

      </model>


     <!----------Provision Area---------->
      <model name="provision_area">
      <pose>-3.8 -3.2 -0.09 0 0 0</pose>

         <!-----Provision Table 1----->
         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/FoodCourtTable1</uri>
           <pose>0 0.5 0.1 0 0 0</pose>
           <name>pro_table1</name>
         </include>

         <!-----Provision Table 2----->
         <include>
           <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/FoodCourtTable1</uri>
           <pose>0 2 0.1 0 0 0</pose>
           <name>pro_table2</name>
         </include>

         <!-----Drinks----->
         <include>
           <uri>https://fuel.gazebosim.org/1.0/GoogleResearch/models/FOOD_BEVERAGE_SET</uri>
           <pose>0 0.5 0.85 0 0 1.57</pose>
           <name>drink_set1</name>
         </include>

         <include>
           <uri>https://fuel.gazebosim.org/1.0/GoogleResearch/models/FOOD_BEVERAGE_SET</uri>
           <pose>0 2 0.85 0 0 1.57</pose>
           <name>drink_set2</name>
         </include>

      </model>


    <!---------------Robot Segment--------------->

    <model name="CyberWaster" canonical_link="chassis">

      <!-----Spawn above ground to avoid clipping----->
      <pose>-3.8 -3.8 0.15 0 0 0</pose>

      <!----------Chassis---------->
      <link name="chassis">

        <!-----Chassis positioned at center/above ground----->
        <pose>0 0 0.12 0 0 0</pose>

        <inertial>
          <mass>2.0</mass>
          <inertia>
            <ixx>0.02</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.02</iyy>
            <iyz>0</iyz>
            <izz>0.02</izz>
          </inertia>
        </inertial>

        <!-----Chassis scaled smaller to match Fuel trash bin----->
        <visual name="visual">
          <geometry>
            <box>
              <size>0.7 0.45 0.20</size>
            </box>
          </geometry>

          <!-----Color of Chassis----->
          <material>
            <ambient>0.5 0 0 1</ambient>
            <diffuse>0.5 0 0 1</diffuse>
            <specular>0.2 0.05 0.05 1</specular>
          </material>
        </visual>

        <!-----For contact with Chassis----->
        <collision name="collision">
          <geometry>
            <box>
              <size>0.7 0.45 0.20</size>
            </box>
          </geometry>
        </collision>

      </link>

      <!-----Left wheel scaled smaller----->
      <link name="left_wheel">

        <!-----x:placed near the back, y: left side, z: wheel at center height----->
        <pose relative_to="chassis">-0.20 0.26 0.00 -1.5707 0 0</pose>

        <inertial>
          <mass>0.3</mass>
          <inertia>
            <ixx>0.001</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.001</iyy>
            <iyz>0</iyz>
            <izz>0.002</izz>
          </inertia>
        </inertial>

        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.12</radius>
              <length>0.06</length>
            </cylinder>
          </geometry>

          <!-----Color of left wheel----->
          <material>
            <ambient>0.05 0.05 0.05 1</ambient>
            <diffuse>0.05 0.05 0.05 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
          </material>
        </visual>

        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.12</radius>
              <length>0.06</length>
            </cylinder>
          </geometry>
        </collision>

      </link>

      <!-----Right wheel scaled smaller----->
      <link name="right_wheel">

        <!-----x:placed near the back, y: right side, z: wheel at center height----->
        <pose relative_to="chassis">-0.20 -0.26 0.00 -1.5707 0 0</pose>

        <inertial>
          <mass>0.3</mass>
          <inertia>
            <ixx>0.001</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.001</iyy>
            <iyz>0</iyz>
            <izz>0.002</izz>
          </inertia>
        </inertial>

        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.12</radius>
              <length>0.06</length>
            </cylinder>
          </geometry>

          <!-----Color of right wheel----->
          <material>
            <ambient>0.05 0.05 0.05 1</ambient>
            <diffuse>0.05 0.05 0.05 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
          </material>
        </visual>

        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.12</radius>
              <length>0.06</length>
            </cylinder>
          </geometry>
        </collision>

      </link>

      <!----- Wheel joints ----->
      <joint name="left_wheel_joint" type="revolute">
        <parent>chassis</parent>
        <child>left_wheel</child>
        <axis>
          <xyz>0 0 1</xyz>
        </axis>
      </joint>

      <joint name="right_wheel_joint" type="revolute">
        <parent>chassis</parent>
        <child>right_wheel</child>
        <axis>
          <xyz>0 0 1</xyz>
        </axis>
      </joint>

      <!-----TrashBin from Fuel Website----->
      <include>
        <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/TrashBin</uri>
        <!-----Placed on top of Chassis----->
        <pose relative_to="chassis">0 0 0.10 0 0 0</pose>
        <name>trash_bin</name>
      </include>

      <!-----Attach the bin to Chassis----->
      <joint name="bin_fixed_to_chassis" type="fixed">
        <parent>chassis</parent>
        <child>trash_bin::body</child>
      </joint>

    </model>
  </world>
</sdf>
